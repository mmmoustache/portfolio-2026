---
import TextSwap from '@/components/TextSwap.astro';

type NavItem = {
  href: string;
  title: string;
};

const date = new Date().getFullYear();
const { items = [] } = Astro.props;
---

<footer class="p-7">
  <div class="grid grid-cols-1 gap-4 xl:grid-cols-3">
    <p class="col-span-1 mt-auto">Built with love. Copyright &copy {date}. All rights reserved.</p>

    <nav id="navigationFooter" aria-label="Footer" class="col-span-2 flex xl:justify-end">
      {
        items?.length > 0 ? (
          <ul class="mt-auto flex gap-5 max-lg:flex-col">
            {items.map((item: NavItem) => (
              <li>
                <a href={item.href} class="font-sub-heading block">
                  <TextSwap text={item.title} class="flex" />
                </a>
              </li>
            ))}
            <li>
              <a href="#" class="font-sub-heading cursor-pointer">
                <TextSwap text="Back to top" class="flex" />
              </a>
            </li>
          </ul>
        ) : null
      }
    </nav>
  </div>
</footer>
<style></style>
