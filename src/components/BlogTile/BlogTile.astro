---
import TextSwap from '@/components/TextSwap/TextSwap.astro';

export type BlogTileProps = {
  href: string;
  image?: string;
  text: string;
  title: string;
};

const { title, text, href, image } = Astro.props;
const hasImage = Boolean(image);
---

<article class="blog-tile text-swapper relative overflow-hidden" data-has-image={hasImage}>
  {
    image && (
      <img
        src={image}
        alt=""
        loading="lazy"
        class="blog-tile-image absolute inset-0 z-0 block h-full w-full object-cover transition-transform duration-700 ease-out"
      />
    )
  }

  <span class="tile-overlay absolute inset-0 z-10" aria-hidden="true"></span>

  {
    href ? (
      <a
        href={href}
        class="blog-tile-link relative z-20 flex h-125 cursor-pointer flex-col gap-3 p-5"
        aria-label={`Read more: ${title}`}
        tabindex="0"
      >
        {title && <h3 class="font-sub-heading">{title}</h3>}
        {text && <p class="font-body">{text}</p>}

        <span class="font-title mt-auto text-right">
          <TextSwap text="Read more" />
        </span>
      </a>
    ) : (
      <div class="relative z-20 flex h-125 flex-col gap-3 p-5">
        {title && <h3 class="font-sub-heading">{title}</h3>}
        {text && <p class="font-body">{text}</p>}
      </div>
    )
  }
</article>

<style>
  .tile-overlay {
    background: transparent;
    transition: background 0.6s ease;
  }

  [data-has-image='true'] .tile-overlay {
    background: rgba(0, 0, 0, 0.4);
  }

  [data-has-image='true'] {
    color: var(--color-white);
  }

  [data-has-image='false'] {
    color: var(--color-black);
  }

  .blog-tile-image {
    transform: scale(1.15);
  }

  .blog-tile:hover .blog-tile-image {
    transform: scale(1);
  }

  .blog-tile:hover .tile-overlay {
    background: rgba(0, 0, 0, 0.6);
  }

  .blog-tile-link {
    box-shadow: 0 0 0 0 inset var(--focus-color);
    transition: box-shadow ease-in-out 0.25s;
  }

  .blog-tile-link:focus-visible {
    box-shadow: 0 0 0 10px inset var(--focus-color);
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-tile-image,
    .blog-tile-link,
    .tile-overlay {
      transition: none;
    }

    .blog-tile:hover .blog-tile-image {
      transform: none;
    }
  }
</style>
