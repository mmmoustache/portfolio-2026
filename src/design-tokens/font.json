{
  "font": {
    "family": {
      "1": {
        "$type": "fontFamily",
        "$value": [
          "Forum",
          "system-ui",
          "-apple-system",
          "Segoe UI",
          "Helvetica Neue",
          "Arial",
          "serif"
        ]
      },
      "2": {
        "$type": "fontFamily",
        "$value": [
          "Outfit",
          "system-ui",
          "-apple-system",
          "Segoe UI",
          "Helvetica Neue",
          "Arial",
          "sans-serif"
        ]
      }
    },
    "size": {
      "base": {
        "$type": "dimension",
        "$value": "18px"
      },
      "1": {
        "$type": "dimension",
        "$value": "14px"
      },
      "2": {
        "$type": "dimension",
        "$value": "{font.size.base}"
      },
      "3": {
        "$type": "dimension",
        "$value": "24px"
      },
      "4": {
        "$type": "dimension",
        "$value": "32px"
      },
      "5": {
        "$type": "dimension",
        "$value": "clamp(1rem, min(20vmin, 10vw), 10rem)"
      }
    },
    "line-height": {
      "1": {
        "$value": 1.5
      },
      "2": {
        "$value": 1.75
      },
      "3": {
        "$value": 1.25
      },
      "4": {
        "$value": 1.1
      },
      "5": {
        "$value": 0.875
      }
    },
    "letter-spacing": {
      "1": {
        "$type": "dimension",
        "$value": "0"
      },
      "2": {
        "$type": "dimension",
        "$value": "1px"
      }
    },
    "weight": {
      "1": {
        "$type": "fontWeight",
        "$value": 400
      },
      "2": {
        "$type": "fontWeight",
        "$value": 700
      },
      "3": {
        "$type": "fontWeight",
        "$value": 300
      }
    },
    "title": {
      "$type": "typography",
      "1": {
        "$value": {
          "fontFamily": "{font.family.1}",
          "fontWeight": "{font.weight.1}",
          "fontSize": "{font.size.5}",
          "lineHeight": "{font.line-height.5}"
        },
        "$extensions": {
          "$targetElement": "h1",
          "$name": "Title 1"
        }
      },
      "2": {
        "$value": {
          "fontFamily": "{font.family.2}",
          "fontWeight": "{font.weight.1}",
          "fontSize": "{font.size.4}",
          "lineHeight": "{font.line-height.4}"
        },
        "$extensions": {
          "$targetElement": "h2"
        }
      },
      "3": {
        "$value": {
          "fontFamily": "{font.family.2}",
          "fontWeight": "{font.weight.3}",
          "fontSize": "{font.size.4}",
          "lineHeight": "{font.line-height.4}"
        },
        "$extensions": {
          "$targetElement": "h3"
        }
      }
    },
    "body": {
      "$type": "typography",
      "1": {
        "$value": {
          "fontFamily": "{font.family.2}",
          "fontWeight": "{font.weight.1}",
          "fontSize": "{font.size.2}",
          "lineHeight": "{font.line-height.1}"
        }
      }
    },
    "button": {
      "$type": "typography",
      "1": {
        "$value": {
          "fontFamily": "{font.family.1}",
          "fontWeight": "{font.weight.1}",
          "fontSize": "{font.size.2}",
          "lineHeight": "{font.line-height.1}"
        }
      }
    }
  }
}
