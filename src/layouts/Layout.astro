---
import '@/styles/global.css';

import Analytics from '@vercel/analytics/astro';
import type { ImageMetadata } from 'astro';

import BaseHead from '@/components/BaseHead/BaseHead.astro';
import Footer from '@/components/Footer/Footer.astro';
import MainNavigation from '@/components/MainNavigation/MainNavigation.astro';
import ScrollProvider from '@/components/ScrollProvider/ScrollProvider.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '@/consts/consts';
import data from '@/data/navigation.json';

type Props = {
  description?: string;
  id?: string;
  image?: ImageMetadata;
  title?: string;
};

const { id, title = SITE_TITLE, description = SITE_DESCRIPTION, image } = Astro.props as Props;

const isVercel = Boolean(process.env.VERCEL);
const isProd = import.meta.env.PROD;
const enableAnalytics = isProd && isVercel;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body id="body">
    <MainNavigation items={data.main} />
    <main id="content" tabindex="-1" data-testid="main" data-layout={id}>
      <slot />
      <ScrollProvider />
    </main>
    <Footer items={data.main} />
    {enableAnalytics && <Analytics />}
  </body>
</html>
