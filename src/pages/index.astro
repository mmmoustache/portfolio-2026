---
import Biography from '@/components/Biography/Biography.astro';
import BlogPromo from '@/components/BlogPromo/BlogPromo.astro';
import Introduction from '@/components/Introduction/Introduction.astro';
import WorkPromo from '@/components/WorkPromo/WorkPromo.astro';
import data from '@/data/homepage.json';
import Layout from '@/layouts/Layout.astro';
---

<Layout id="home">
  <Introduction title={data?.introduction?.title} />
  <Biography title={data?.bio?.title} text={data?.bio?.text} tools={data?.bio?.tools} />
  <WorkPromo title={data?.work?.title} text={data?.work?.text} items={data?.work?.items} />
  <BlogPromo title={data?.blog?.title} text={data?.blog?.text} />
</Layout>
