---
import TextSwap from '@/components/TextSwap/TextSwap.astro';
import { SITE_AUTHOR } from '@/consts/consts';

type NavItem = {
  externalLink: boolean;
  href: string;
  title: string;
};

const { items = [] } = Astro.props;
---

<a
  href="#content"
  class="skip-to-content | font-body absolute top-0 left-0 -m-px h-px w-px overflow-hidden border-0 bg-white p-0 whitespace-nowrap focus:m-0 focus:h-auto focus:w-auto focus:overflow-visible focus:p-5 focus:whitespace-normal"
  >Skip to content</a
>

<header id="headerStatic" class="header | absolute top-0 left-0 z-30 hidden w-full lg:flex">
  <nav class="w-full" aria-label="Primary">
    {
      items?.length > 0 ? (
        <ul class="font-body flex justify-between">
          <li>
            <a href="/" class="font-body z-40 block p-5 lg:px-7">
              {SITE_AUTHOR}
            </a>
          </li>
          {items.map((item: NavItem) => {
            const openInNewTab = Boolean(item?.externalLink);
            const attributes = {
              href: item.href,
              ...(openInNewTab
                ? {
                    target: '_blank',
                    rel: 'noopener noreferrer',
                  }
                : null),
            };
            return (
              <li>
                <a {...attributes} class="block">
                  <TextSwap text={item.title} class="flex px-7 py-5" />
                </a>
              </li>
            );
          })}
        </ul>
      ) : null
    }
  </nav>
</header>

<header id="header" class="header | absolute top-0 left-0 z-30 flex w-full">
  <a href="/" class="site-author | font-body z-40 block p-5 lg:px-7">{SITE_AUTHOR}</a>

  <button
    id="navigationToggle"
    type="button"
    class="group relative z-40 m-1 ml-auto grid h-14.5 min-w-11 cursor-pointer place-items-center border-0 bg-white px-3 focus-visible:outline focus-visible:outline-current"
    aria-controls="navigation"
    aria-expanded="false"
    aria-label="Open menu"
    data-state="closed"
  >
    <span class="relative block h-3.75 w-8.5" aria-hidden="true">
      <span
        class="absolute top-1/2 left-0 h-px w-8.5 origin-center -translate-y-1.25 bg-black transition-transform duration-200 ease-in-out group-data-[state=open]:translate-y-0 group-data-[state=open]:rotate-45 motion-reduce:transition-none"
      ></span>
      <span
        class="absolute top-1/2 left-0 h-px w-8.5 origin-center translate-y-1.25 bg-black transition-transform duration-200 ease-in-out group-data-[state=open]:translate-y-0 group-data-[state=open]:-rotate-45 motion-reduce:transition-none"
      ></span>
    </span>
  </button>

  <nav
    id="navigation"
    class="bg-secondary-light fixed top-0 left-0 z-30 hidden h-dvh w-dvw items-center justify-center pt-0"
    aria-label="Primary"
  >
    {
      items?.length > 0 ? (
        <ul
          class="font-body flex max-h-full w-full flex-col items-center justify-between overflow-auto text-center opacity-0"
          data-lenis-prevent
          id="navigationItems"
        >
          {items.map((item: NavItem) => {
            const openInNewTab = Boolean(item?.externalLink);
            const attributes = {
              href: item.href,
              ...(openInNewTab
                ? {
                    target: '_blank',
                    rel: 'noopener noreferrer',
                  }
                : null),
            };
            return (
              <li>
                <a {...attributes} class="font-heading block">
                  <TextSwap
                    text={item.title}
                    class="flex px-7 py-5 leading-[1.2em] max-lg:leading-[1.1em]"
                  />
                </a>
              </li>
            );
          })}
        </ul>
      ) : null
    }
  </nav>
</header>

<style>
  .header {
    height: var(--navigation-height);
  }

  /* Hide site logo when in sticky style */
  .header.fixed .site-author {
    display: none;
  }

  /* Show site logo when in sticky style, but navigation is open */
  .header.fixed .site-author:has(+ #navigationToggle[aria-expanded='true']) {
    display: block;
  }

  /* When the header is static, hide the navigation toggle on large screens */
  .header:not(.fixed) #navigationToggle,
  .header:not(.fixed) .site-author {
    @media (width >= 64rem) {
      display: none;
    }
  }

  /* Hide the fixed navigation when it's not in a fixed state on large screens */
  #headerStatic + .header:not(.fixed) {
    @media (width >= 64rem) {
      display: none;
    }
  }

  /* Show navigation toggle when navigation is open */
  #navigationToggle:has(+ #navigation:not(.hidden)) {
    display: block;
  }

  /* Toggle */
  .toggle:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 4px;
  }

  [data-toggle-line] {
    top: 50%;
    transform-origin: center;
    transition:
      transform 180ms ease,
      opacity 180ms ease;
  }

  [data-toggle-line='1'] {
    transform: translateY(-7px) rotate(0deg);
  }

  [data-toggle-line='2'] {
    transform: translateY(7px) rotate(0deg);
  }

  .toggle[aria-expanded='true'] [data-toggle-line='1'] {
    transform: translateY(0) rotate(45deg);
  }

  .toggle[aria-expanded='true'] [data-toggle-line='2'] {
    transform: translateY(0) rotate(-45deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .toggle__line {
      transition: none;
    }
  }

  .navigation-offset {
    padding-top: var(--navigation-height);

    @media (width >= 64rem) {
      padding-top: 0;
    }
  }

  .skip-to-content {
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
  }

  .skip-to-content:focus {
    clip: auto;
    clip-path: none;
    z-index: 2147483647;
  }
</style>

<script>
  import { initNavigationMenu } from '@/components/MainNavigation/MainNavigation';

  initNavigationMenu();
</script>
