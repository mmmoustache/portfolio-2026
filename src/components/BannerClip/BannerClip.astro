---
export type Props = {
  class?: string;
  ease?: number;
  initialInsetPercentage?: number;
  initialScale?: number;
};

const {
  class: className = '',
  ease = 0.12,
  initialInsetPercentage = 30,
  initialScale = 1.15,
} = Astro.props;
---

<section
  class={`banner-clip | w-full | ${className}`}
  data-banner-clip
  data-initial-inset={initialInsetPercentage}
  data-initial-scale={initialScale}
  data-ease={ease}
>
  <div
    class="banner-clip__inner | h-auto w-full overflow-hidden"
    style={`--inset: ${initialInsetPercentage}%; --scale: ${initialScale};`}
  >
    <slot />
  </div>
</section>

<style>
  .banner-clip__inner {
    clip-path: inset(var(--inset) var(--inset) var(--inset) var(--inset));
    transform: scale(var(--scale));
    transform-origin: center center;
    will-change: clip-path, transform;
  }

  .banner-clip :global(img),
  .banner-clip :global(video) {
    display: block;
    height: auto;
    width: 100%;
  }

  @media (prefers-reduced-motion: reduce) {
    .banner-clip__inner {
      clip-path: none !important;
      transform: none !important;
    }
  }
</style>

<script>
  import { BannerClip } from '@/components/BannerClip/BannerClip';
  BannerClip();
</script>
