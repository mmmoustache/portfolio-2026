---
import '@/styles/global.css';

import Analytics from '@vercel/analytics/astro';

import Footer from '@/components/Footer/Footer.astro';
import BaseHead from '@/components/BaseHead/BaseHead.astro';
import MainNavigation from '@/components/MainNavigation/MainNavigation.astro';
import ScrollProvider from '@/components/ScrollProvider/ScrollProvider.astro';

import data from '@/data/navigation.json';

import { SITE_TITLE, SITE_DESCRIPTION } from '@/consts/consts';

const { id } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body id="body">
    <MainNavigation items={data.main} />
    <main id="content" tabindex="-1" data-testid="main" data-layout={id}>
      <slot />
      <ScrollProvider />
    </main>
    <Footer items={data.main} />
    <Analytics />
  </body>
</html>
