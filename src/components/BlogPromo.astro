---
import type { BlogTileProps } from '@/components/BlogTile.astro';
import BlogTile from '@/components/BlogTile.astro';

type Props = {
  title: string;
  text?: string;
  items: Array<BlogTileProps>;
};

const { title, text, items } = Astro.props;
---

<section class="flex flex-col gap-6 p-7">
  {
    title && (
      <h1 class="font-heading text-center text-amber-300">
        {title}<span class="text-amber-300">.</span>
      </h1>
    )
  }
  {text && <p class="font-sub-heading text-center">{text}</p>}
  {
    items.length > 0 ? (
      <ul class="mx-auto grid max-w-7xl grid-cols-3 gap-4">
        {items?.map((item) => (
          <li class="col-span-1">
            <BlogTile title={item.title} text={item.text} href={item.href} />
          </li>
        ))}
      </ul>
    ) : null
  }
</section>
