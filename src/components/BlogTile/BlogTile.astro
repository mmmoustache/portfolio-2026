---
import TextSwap from '../TextSwap/TextSwap.astro';

export type BlogTileProps = {
  headingLevel?: 2 | 3 | 4 | 5 | 6;
  href: string;
  title: string;
};

const { title, href, headingLevel = 3 } = Astro.props;
const HeadingTag = `h${headingLevel}` as keyof HTMLElementTagNameMap;
---

<article
  class="blog-tile | text-swapper bg-primary hover:bg-tertiary-light relative overflow-hidden transition-colors duration-500"
  data-testid="blog-tile"
>
  {
    (
      <a
        href={href}
        class="blog-tile-link | relative z-20 flex h-64 cursor-pointer flex-col p-5 xl:h-125"
        aria-label={`Read more: ${title}`}
      >
        {title && <HeadingTag class="font-sub-heading">{title}</HeadingTag>}
        <span class="font-title mt-auto block text-right">
          <TextSwap text="Read more" />
        </span>
      </a>
    )
  }
</article>

<style>
  .blog-tile-link {
    box-shadow: 0 0 0 0 inset var(--focus-color);
    transition: box-shadow ease-in-out 0.25s;
  }

  .blog-tile-link:focus-visible {
    box-shadow: 0 0 0 10px inset var(--focus-color);
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-tile-link {
      transition: none;
    }
  }
</style>
