---
import '@/styles/global.css';

import type { ImageMetadata } from 'astro';

import FallbackImage from '@/assets/me.webp';
import { SITE_TITLE } from '@/consts/consts';

type Props = {
  description: string;
  image?: ImageMetadata;
  ogType?: 'article' | 'website';
  publishedTime?: Date;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  title: string;
  updatedTime?: Date;
};

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
  title,
  description,
  image = FallbackImage,
  ogType = 'website',
  publishedTime,
  schema,
  updatedTime,
} = Astro.props;
const imageURL = new URL(image.src, Astro.site ?? Astro.url);
const schemaItems = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE_TITLE}
  href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
{updatedTime && <meta property="article:modified_time" content={updatedTime.toISOString()} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

{
  schemaItems.map((item) => (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(item)} />
  ))
}
