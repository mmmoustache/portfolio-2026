---
import TextSwap from '@/components/TextSwap.astro';
import { SITE_AUTHOR } from '@/consts/consts';

type NavItem = {
  href: string;
  title: string;
  externalLink: boolean;
};

const { items = [] } = Astro.props;
---

<header id="header" class="header | absolute z-30 w-full max-lg:flex">
  <a href="/" class="font-body z-40 block p-5 lg:hidden lg:px-7">{SITE_AUTHOR}</a>

  <button
    id="navigationToggle"
    type="button"
    class="font-body z-40 ml-auto block cursor-pointer p-5 lg:hidden lg:px-7"
    aria-controls="navigation"
    aria-expanded="false"
  >
    Menu
  </button>

  <nav
    id="navigation"
    class="hidden max-lg:fixed max-lg:top-0 max-lg:left-0 max-lg:z-30 max-lg:h-dvh max-lg:w-dvw max-lg:items-center max-lg:justify-center max-lg:bg-amber-300 lg:block lg:pt-0"
    aria-label="Primary"
  >
    {
      items?.length > 0 ? (
        <ul
          class="font-body flex justify-between max-lg:max-h-full max-lg:w-full max-lg:flex-col max-lg:items-center max-lg:overflow-auto max-lg:text-center max-lg:opacity-0"
          data-lenis-prevent
          id="navigationItems"
        >
          <a href="/" class="px-7 py-5 max-lg:hidden">
            {SITE_AUTHOR}
          </a>
          {items.map((item: NavItem) => {
            const openInNewTab = Boolean(item?.externalLink);
            const attributes = {
              href: item.href,
              ...(openInNewTab
                ? {
                    target: '_blank',
                    rel: 'noopener noreferrer',
                  }
                : null),
            };
            return (
              <li>
                <a {...attributes} class="max-lg:font-heading block">
                  <TextSwap text={item.title} class="flex px-7 py-5" />
                </a>
              </li>
            );
          })}
        </ul>
      ) : null
    }
  </nav>
</header>

<style>
  .header {
    height: var(--navigation-height);
  }

  .navigation-offset {
    padding-top: var(--navigation-height);

    @media (width >= 64rem) {
      padding-top: 0;
    }
  }
</style>

<script>
  import { navigationOpen, navigationToggle } from '@/store/navigation.js';
  import { createFocusTrap } from '@/utils/focusTrap';

  const toggle = document.getElementById('navigationToggle');
  const navEl = document.getElementById('navigation');
  const navItemsEl = document.getElementById('navigationItems');
  const header = document.getElementById('header');

  let releaseTrap: (() => void) | null = null;
  let previousBodyOverflow = '';

  const lgMq = window.matchMedia('(min-width: 64rem)');
  let isLg = lgMq.matches;

  function stopLenis() {
    window.__lenis?.stop?.();
  }

  function startLenis() {
    window.__lenis?.start?.();
  }

  function setUI(open: boolean) {
    if (!toggle || !navEl) return;

    if (open) {
      previousBodyOverflow = document.body.style.overflow;

      document.body.classList.add('max-lg:overflow-hidden', 'max-lg:h-dvh');
      navEl.classList.add('navigation-offset', 'flex', 'motion-safe:animate-fade-in');
      navEl.classList.remove('hidden');

      setTimeout(() => {
        navItemsEl?.classList.add('motion-safe:animate-shift-up');
      }, 250);

      stopLenis();
    } else {
      document.body.style.overflow = previousBodyOverflow || '';
      document.body.classList.remove('max-lg:overflow-hidden', 'max-lg:h-dvh');
      navEl.classList.remove('navigation-offset', 'flex', 'motion-safe:animate-fade-in');
      navItemsEl?.classList.remove('motion-safe:animate-shift-up');

      navEl.classList.add('hidden');

      startLenis();
    }

    toggle.textContent = open ? 'Close' : 'Menu';
    toggle.setAttribute('aria-expanded', String(open));
  }

  function openNav() {
    if (!toggle || !navEl || !header) return;

    setUI(true);
    releaseTrap?.();
    releaseTrap = createFocusTrap(header, {
      initialFocus: 'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
      onEscape: () => navigationOpen.set(false),
    });
  }

  function closeNav() {
    setUI(false);
    releaseTrap?.();
    releaseTrap = null;
  }

  function handleBreakpointChange(e: { matches: any }) {
    const nextIsLg = e.matches;

    if (nextIsLg && !isLg) {
      navigationOpen.set(false);
      closeNav();
      startLenis();
    }

    if (!nextIsLg && isLg) {
      if (navigationOpen.get?.() === true) stopLenis();
    }

    isLg = nextIsLg;
  }

  if (toggle && navEl) {
    setUI(navigationOpen.get());

    const unsubscribe = navigationOpen.subscribe((open) => {
      if (lgMq.matches) {
        if (open) navigationOpen.set(false);
        return;
      }

      if (open) openNav();
      else closeNav();
    });

    toggle.addEventListener('click', () => {
      if (!lgMq.matches) navigationToggle();
    });

    lgMq.addEventListener('change', handleBreakpointChange);

    const cleanup = () => {
      closeNav();
      unsubscribe?.();
      lgMq.removeEventListener('change', handleBreakpointChange);
      toggle.removeEventListener('click', navigationToggle);
    };

    document.addEventListener('astro:before-swap', cleanup);
    window.addEventListener('pagehide', cleanup);
  }
</script>
