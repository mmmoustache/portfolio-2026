---
import { splitGraphemes } from '@/utils/splitGraphemes';

export interface Props {
  as?: keyof HTMLElementTagNameMap;
  class?: string;
  staggerMs?: number;
  text: string;
}

const { text, as = 'span', class: className = '', staggerMs = 24 } = Astro.props;
const Tag = as;
const chars = splitGraphemes(text);
---

<Tag
  aria-label={text}
  class={`text-swap | relative inline-block | ${className}`}
  style={`--stagger: ${staggerMs}ms;`}
>
  {
    chars.map((ch, i) => (
      <span class="relative inline-block overflow-hidden align-bottom" style={`--i:${i}`}>
        <span class="top | inline-block will-change-transform">{ch === ' ' ? '\u00A0' : ch}</span>
        <span class="bottom | absolute top-0 left-0 inline-block will-change-transform">
          {ch === ' ' ? '\u00A0' : ch}
        </span>
      </span>
    ))
  }
</Tag>

<style is:global>
  .text-swap {
    --stagger: 24ms;
    --duration: 320ms;
    --ease: var(--motion-ease-text-swap);
  }

  .text-swap .top,
  .text-swap .bottom {
    transition-delay: 0ms;
    transition-duration: var(--duration);
    transition-property: transform;
    transition-timing-function: var(--ease);
  }

  .text-swap .bottom {
    transform: translateY(104%);
  }

  .text-swap::after {
    background-color: var(--color-tertiary);
    content: '';
    display: block;
    height: 0.2em;
    position: relative;
    top: 0.1em;
    transition: width 180ms ease-out;
    width: 0;
  }

  @media (hover: hover) {
    .text-swapper:hover .text-swap .top,
    .text-swapper:hover .text-swap .bottom,
    .text-swap:hover .top,
    .text-swap:hover .bottom {
      transition-delay: calc(var(--i) * var(--stagger));
    }

    .text-swapper:hover .text-swap .top,
    .text-swap:hover .top {
      transform: translateY(-104%);
    }

    .text-swapper:hover .text-swap .bottom,
    .text-swap:hover .bottom {
      transform: translateY(0);
    }

    .text-swap:hover::after,
    .text-swapper:hover .text-swap::after {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .text-swap .top,
    .text-swap .bottom {
      transition: none;
    }
  }
</style>
