---
import { Image } from 'astro:assets';

import Portrait from '@/assets/me.webp';
import BannerImage from '@/assets/ocean.webp';
import BannerClip from '@/components/BannerClip/BannerClip.astro';
import Dot from '@/components/Dot/Dot.astro';
import LogoBlock from '@/components/LogoBlock/LogoBlock.astro';
import SwipeImage from '@/components/SwipeImage/SwipeImage.astro';

export type Tool = {
  id: string;
  name: string;
};

type Props = {
  text?: string;
  title: string;
  tools: Array<Tool>;
};

const { title, text, tools } = Astro.props;
---

<section class="-mt-9 overflow-hidden">
  <div class="mx-auto flex max-w-6xl">
    <BannerClip initialInsetPercentage={18} initialScale={1.34} ease={0.09}>
      <Image
        src={BannerImage}
        alt="A landscape photography of an ocean on a sunny day"
        loading="lazy"
        widths={[720, 1080, 1440]}
        sizes="(min-width: 1280px) 72rem, 100vw"
      />
    </BannerClip>
  </div>
</section>

<section class="bg-tertiary-light -mt-9 min-h-dvh">
  <div class="layout-content | py-7">
    <div class="my-10 grid grid-cols-1 gap-8 lg:grid-cols-3">
      <div class="col-span-1 lg:col-span-2">
        <h2 class="font-heading">
          {title}<Dot />
        </h2>
        {text && <p class="font-body lg:font-title pt-6 text-left">{text}</p>}
        <div class="flex flex-col gap-5 py-8">
          <LogoBlock items={tools} />
        </div>
      </div>
      <div class="col-span-1 lg:col-span-1">
        <div class="mx-auto max-w-80 lg:w-full lg:max-w-full">
          <SwipeImage
            threshold={0.18}
            delayMs={80}
            durationMs={900}
            easing="var(--motion-ease-settle)"
          >
            <Image
              src={Portrait}
              alt="Portrait of Jack Coventry holding a koala"
              loading="lazy"
              widths={[320, 480, 640]}
              sizes="(min-width: 1024px) 20rem, 80vw"
            />
          </SwipeImage>
        </div>
      </div>
    </div>
  </div>
</section>
