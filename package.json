{
  "name": "jc",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev --host",
    "build": "npm run tokens && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier . --write",
    "tokens": "node config/style-dictionary.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "verify": "npm run prettier && npm run lint && npm run typecheck && npm run test:run && npm run bundle:budget:ci",
    "prepare": "husky",
    "lh:ci": "node src/scripts/lighthouse.mjs",
    "lh:preview": "astro preview --host 127.0.0.1 --port 4321",
    "lh:local": "npm run build && start-server-and-test lh:preview http://127.0.0.1:4321 \"LH_BASE_URL=http://127.0.0.1:4321 node src/scripts/lighthouse.mjs\"",
    "bundle:budget": "node src/scripts/bundle-budget.mjs",
    "bundle:budget:ci": "npm run build && npm run bundle:budget"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,astro,json,md,css}": [
      "prettier . --check"
    ],
    "*.{js,jsx,ts,tsx,astro}": [
      "eslint ."
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vercel/analytics": "^1.6.1",
    "astro": "^5.18.0",
    "lenis": "^1.3.17",
    "nanostores": "^1.1.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "astro-eslint-parser": "^1.3.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.3.1",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "start-server-and-test": "^2.1.5",
    "style-dictionary": "^5.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
