---
import TextSwap from '@/components/TextSwap/TextSwap.astro';
import { SITE_AUTHOR } from '@/consts/consts';

type NavItem = {
  externalLink?: boolean;
  href: string;
  label: string;
};

interface Props {
  items: NavItem[];
}

const { items = [] } = Astro.props;
---

<a
  href="#content"
  class="skip-to-content | font-body absolute top-2 left-2 z-70 -m-px h-px w-px overflow-hidden border-0 bg-white p-0 whitespace-nowrap focus:m-0 focus:h-auto focus:w-auto focus:overflow-visible focus:p-5 focus:whitespace-normal"
  >Skip to content</a
>

<header class="absolute z-50 w-full" id="siteHeader" data-testid="main-nav">
  <nav id="desktopNav" class="hidden lg:block" aria-label="Masthead navigation">
    <ul class="flex h-20 items-center justify-between gap-8">
      <li>
        <a id="desktopLogo" href="/" class="inline-flex items-center gap-3">
          <span class="font-body p-6">{SITE_AUTHOR}</span>
        </a>
      </li>
      {
        items.slice(0, 3).map((item: NavItem) => {
          const openInNewTab = Boolean(item?.externalLink);
          const attributes = {
            href: item.href,
            ...(openInNewTab
              ? {
                  target: '_blank',
                  rel: 'noopener noreferrer',
                }
              : null),
          };
          return (
            <li>
              <a {...attributes} class="font-body block">
                <TextSwap text={item.label} class="flex p-6" />
              </a>
            </li>
          );
        })
      }
    </ul>

    <div id="desktopNavSentinel" class="h-px w-full" aria-hidden="true"></div>
  </nav>

  <div
    id="mobileBar"
    class="fixed top-0 right-0 left-0 z-70 transition-opacity transition-transform motion-reduce:transition-none"
    data-at-top="true"
    data-menu-open="false"
  >
    <nav aria-label="Primary navigation" class="layout-content">
      <div class="flex h-16 items-center justify-between">
        <a
          href="/"
          id="mobileLogo"
          class="inline-flex items-center opacity-0"
          aria-hidden="true"
          tabindex="-1"
        >
          <span class="font-body">{SITE_AUTHOR}</span>
        </a>

        <button
          id="menuToggle"
          type="button"
          class="hover:bg-tertiary-light relative inline-flex h-12 w-12 cursor-pointer items-center justify-center bg-white motion-reduce:transform-none"
          aria-haspopup="dialog"
          aria-controls="mobileMenu"
          aria-expanded="false"
        >
          <span class="sr-only">Open menu</span>

          <span
            aria-hidden="true"
            data-line="top"
            class="absolute block h-px w-5 bg-black transition-transform motion-reduce:transition-none"
          ></span>
          <span
            aria-hidden="true"
            data-line="bottom"
            class="absolute block h-px w-5 bg-black transition-transform motion-reduce:transition-none"
          ></span>
        </button>
      </div>
    </nav>
  </div>

  <div
    id="mobileMenu"
    class="pointer-events-none fixed inset-0 z-60 bg-white opacity-0 transition-opacity motion-reduce:transition-none"
    role="dialog"
    aria-modal="true"
    aria-label="Menu"
    tabindex="-1"
    aria-hidden="true"
    hidden
  >
    <div class="h-full w-full" data-menu-overlay>
      <div
        class="layout-content h-dvh max-w-6xl content-center py-[calc(var(--nav-offset)+2rem)]"
        data-menu-panel
      >
        <ul class="h-full content-center overflow-auto" data-lenis-prevent>
          {
            items.map((item: NavItem) => {
              const openInNewTab = Boolean(item?.externalLink);
              const attributes = {
                href: item.href,
                ...(openInNewTab
                  ? {
                      target: '_blank',
                      rel: 'noopener noreferrer',
                    }
                  : null),
              };
              return (
                <li class="p-2">
                  <a {...attributes} class="font-heading block text-center">
                    <TextSwap
                      text={item.label}
                      class="flex leading-[1.2em] max-lg:leading-[1.1em]"
                    />
                  </a>
                </li>
              );
            })
          }
        </ul>
      </div>
    </div>
  </div>

  <style>
    #mobileBar {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    @media (min-width: 1024px) {
      #mobileBar {
        opacity: 0;
        transform: translateY(-8px);
        pointer-events: none;
      }

      #mobileBar.bar-visible {
        opacity: 1 !important;
        transform: translateY(0) !important;
        pointer-events: auto !important;
      }
    }

    #mobileLogo.js-ready {
      transition: opacity 180ms;
    }

    @media (prefers-reduced-motion: reduce) {
      #mobileLogo.js-ready {
        transition: none;
      }
    }

    #menuToggle [data-line='top'] {
      transform: translateY(-6px) rotate(0deg);
    }

    #menuToggle [data-line='bottom'] {
      transform: translateY(6px) rotate(0deg);
    }

    #menuToggle[aria-expanded='true'] [data-line='top'] {
      transform: translateY(0px) rotate(45deg);
    }

    #menuToggle[aria-expanded='true'] [data-line='bottom'] {
      transform: translateY(0px) rotate(-45deg);
    }
  </style>
</header>

<script>
  import '@/components/MainNavigation/MainNavigation.client';
</script>
